# build output — Swift
.build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
Package.resolved

# release / packaging
build/
dist/
out/
*.xcarchive
*.dmg

# os
.DS_Store

# editor
.vscode/*
!.vscode/extensions.json
.idea/

# env / secrets — NUNCA versionar credencial
# ATENÇÃO: NÃO usar glob largo tipo **/*token* ou **/*secret* aqui.
# O projeto se chama MyTokens, o git no macOS é case-insensitive, e esse glob engolia
# MyTokensCore/, MyTokensUI/ e MyTokens.xcodeproj INTEIROS — o código sumia do git em
# silêncio, sem erro nenhum. Foi bug real, custou o commit de três agentes.
# Segredo do usuário vai pro Keychain (regra 4), não pra arquivo em disco. O de baixo
# é só rede de proteção contra acidente:
.env
.env.*
*.pem
*.key
*.p12
*.p8
*.mobileprovision
credentials.json

# screenshots gerados pela bancada (./shots.sh). São artefato, não fonte — e o estado
# `real` fotografa o gasto REAL da máquina de quem rodou. Não versionar.
MyTokensUI/shots/

# logs
*.log

# test/coverage
coverage/

# maestri workspace metadata (não é parte do produto)
.maestri/
